---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  publishDate?: string;
  author?: string;
}

const { title, description, ogImage = '/og-default.png', publishDate, author = 'Patrick Dyer' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://humaninthelooptalent.com');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Human in the Loop Talent</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts — Inter (matches Lovable site) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-L5PRS8ELQE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-L5PRS8ELQE');
  </script>

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://humaninthelooptalent.com${ogImage}`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Human in the Loop Talent" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://humaninthelooptalent.com${ogImage}`} />

  {publishDate && <meta property="article:published_time" content={publishDate} />}
  <meta property="article:author" content={author} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "author": {
      "@type": "Person",
      "name": "Patrick Dyer",
      "url": "https://www.linkedin.com/in/patdyer/",
      "affiliation": {
        "@type": "Organization",
        "name": "Human in the Loop Talent",
        "url": "https://humaninthelooptalent.com"
      }
    },
    "publisher": {
      "@type": "Organization",
      "name": "Human in the Loop Talent",
      "url": "https://humaninthelooptalent.com"
    },
    "mainEntityOfPage": canonicalUrl.toString(),
    ...(publishDate ? { "datePublished": publishDate } : {}),
    "image": `https://humaninthelooptalent.com${ogImage}`
  })} />

  <style>
    /* ── Reset ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    /* ── Brand tokens (from Lovable site) ── */
    :root {
      --bg:              hsl(40, 20%, 97%);      /* cream */
      --fg:              hsl(220, 25%, 10%);      /* dark navy */
      --accent:          hsl(162, 72%, 40%);      /* teal */
      --accent-fg:       #fff;
      --muted:           hsl(220, 10%, 46%);
      --muted-light:     hsl(40, 10%, 92%);
      --border:          hsl(220, 15%, 88%);
      --surface:         hsl(40, 15%, 95%);
      --surface-elevated:#fff;
      --radius:          0.5rem;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Nav (matches Lovable Navbar) ── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: hsla(40, 20%, 97%, 0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 4rem;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--fg);
    }

    .nav-brand .accent { color: var(--accent); margin-left: 0.25rem; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .nav-links a {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--fg); }

    .nav-cta {
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--fg);
      color: var(--bg);
      padding: 0.5rem 1rem;
      border-radius: var(--radius);
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .nav-cta:hover { opacity: 0.9; }

    /* ── Container ── */
    .container {
      max-width: 48rem;
      margin: 0 auto;
      padding: 3rem 1.5rem 4rem;
    }

    /* ── Typography ── */
    h1 {
      color: var(--fg);
      font-size: 2.25rem;
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .meta {
      color: var(--muted);
      font-size: 0.875rem;
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    h2 {
      color: var(--accent);
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }

    h3 {
      color: var(--fg);
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    p {
      color: var(--muted);
      margin-bottom: 1.25rem;
    }

    a { color: var(--accent); }

    ul, ol {
      margin: 0.75rem 0 1.25rem 1.5rem;
      color: var(--muted);
    }

    li { margin-bottom: 0.5rem; }

    strong { color: var(--fg); font-weight: 600; }

    blockquote {
      border-left: 3px solid var(--accent);
      padding: 1rem 1.5rem;
      margin: 1.5rem 0;
      background: var(--surface);
      border-radius: 0 var(--radius) var(--radius) 0;
    }

    blockquote p { color: var(--fg); margin: 0; }

    /* ── CTA Box ── */
    .cta-box {
      background: var(--surface-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      margin: 3rem 0;
      text-align: center;
    }

    .cta-box h3 { color: var(--fg); margin-top: 0; }
    .cta-box p { color: var(--muted); }

    .cta-box a.cta-btn {
      display: inline-block;
      background: var(--fg);
      color: var(--bg);
      padding: 0.75rem 2rem;
      border-radius: var(--radius);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      margin-top: 0.5rem;
      transition: opacity 0.15s;
    }

    .cta-box a.cta-btn:hover { opacity: 0.9; }

    /* ── Footer (matches Lovable FooterSection) ── */
    .footer {
      border-top: 1px solid var(--border);
      padding: 3rem 0;
    }

    .footer-inner {
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .footer-top {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    @media (min-width: 768px) {
      .footer-top {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
      }
    }

    .footer-brand {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 0.25rem;
    }

    .footer-brand .accent { color: var(--accent); margin-left: 0.25rem; }

    .footer-tagline {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .footer-links {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .footer-links a {
      font-size: 0.75rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .footer-links a:hover { color: var(--fg); }

    .footer-links .footer-btn {
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--fg);
      color: var(--bg);
      padding: 0.5rem 1rem;
      border-radius: var(--radius);
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .footer-links .footer-btn:hover { opacity: 0.9; }

    .footer-links .footer-btn-outline {
      font-size: 0.75rem;
      font-weight: 500;
      border: 1px solid var(--border);
      color: var(--fg);
      padding: 0.5rem 1rem;
      border-radius: var(--radius);
      text-decoration: none;
      transition: background 0.15s;
    }

    .footer-links .footer-btn-outline:hover { background: var(--muted-light); }

    .footer-bottom {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 640px) {
      .footer-bottom {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
      }
    }

    .footer-copyright {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .footer-legal {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .footer-legal a {
      font-size: 0.75rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .footer-legal a:hover { color: var(--fg); }

    /* ── Mobile hamburger ── */
    .nav-mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--fg);
      cursor: pointer;
      padding: 0.25rem;
    }

    @media (max-width: 767px) {
      .nav-links { display: none; }
      .nav-mobile-toggle { display: block; }
      h1 { font-size: 1.75rem; }
      .container { padding: 2rem 1.25rem 3rem; }
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <!-- ── Nav ── -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="https://humaninthelooptalent.com" class="nav-brand">
        <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="16" cy="16" rx="12" ry="6" transform="rotate(-25 16 16)" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <ellipse cx="16" cy="16" rx="12" ry="6" transform="rotate(35 16 16)" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <circle cx="16" cy="16" r="2.5" fill="hsl(162, 72%, 40%)"/>
          <circle cx="27" cy="13" r="1.5" fill="currentColor"/>
          <circle cx="5" cy="19" r="1.5" fill="currentColor"/>
        </svg>
        Human in the Loop<span class="accent">Talent</span>
      </a>

      <div class="nav-links">
        <a href="https://humaninthelooptalent.com/#framework">Framework</a>
        <a href="https://humaninthelooptalent.com/#services">Services</a>
        <a href="/insights">Insights</a>
        <a href="https://humaninthelooptalent.com/#diagnostic" class="nav-cta">Run Hiring Diagnostic</a>
      </div>

      <button class="nav-mobile-toggle" id="mobile-toggle" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M3 6H17M3 10H17M3 14H17" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- ── Content ── -->
  <main class="container">
    <h1>{title}</h1>
    <div class="meta">
      {publishDate && <span>{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
      {publishDate && <span> · </span>}
      <span>{author}</span>
    </div>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div>
          <div class="footer-brand">Human in the Loop<span class="accent">Talent</span></div>
          <div class="footer-tagline">AI-Augmented Workforce Architecture</div>
        </div>

        <div class="footer-links">
          <a href="mailto:inquiry@humanintheloop.com">Contact</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://humaninthelooptalent.com/#diagnostic" class="footer-btn">Run Hiring Diagnostic</a>
          <a href="https://calendar.app.google/uwpZw9K6raiwU3m29" target="_blank" rel="noopener noreferrer" class="footer-btn-outline">Book Free Consultation</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-copyright">&copy; 2026 Human in the Loop Talent. All rights reserved.</p>
        <div class="footer-legal">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
