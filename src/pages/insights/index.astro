      --accent:          hsl(162, 72%, 40%);
      --muted:           hsl(220, 10%, 46%);
      --muted-light:     hsl(40, 10%, 92%);
      --border:          hsl(220, 15%, 88%);
      --surface:         hsl(40, 15%, 95%);
      --surface-elevated:#fff;
      --radius:          0.5rem;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
